[0.097, "o", "\u001b[?2026h\r\u001b[8A\u001b[92m⏺\u001b[7C\u001b[39med for \u001b[1m2\u001b[22m pat\u001b[1Cerns \u001b[37m(ctrl+o to expand)\u001b[39m  \r\u001b[2B\u001b[97m⏺\u001b[1C\u001b[39mAll 5 agents deployed successfully. Here's\u001b[1Cthe\u001b[1Cfull\u001b[1Cdeployment\u001b[1Csummary:\r\u001b[2B  ---                                                                           \u001b[1C   \u001b[1C \r\u001b[1B  \u001b[1mClearHealth Platform — Full Implementation Complete\r\u001b[1B\u001b[22m                                                                                      \r\u001b[2C\u001b[1B\u001b[1mAgent Deployment Timeline\u001b[22m                                 \r\r\n\r\r\n\u001b[2C┌───────┬──────────┬────────┬────────────────────────────────────────────────────┐\r\r\n\u001b[2C│\u001b[1CPhase\u001b[1C│\u001b[2CAgent\u001b[3C│\u001b[1CStatus\u001b[1C│\u001b[23COutput\u001b[23C│\r\r\n\u001b[2C├───────┼──────────┼────────┼──────────────────────"]
[0.000, "o", "──────────────────────────────┤\r\r\n\u001b[2C│\u001b[7C│\u001b[10C│\u001b[8C│\u001b[1C\u001b[94mprisma/seed.ts\u001b[1C\u001b[39m—\u001b[1C725\u001b[1Clines,\u001b[1C2\u001b[1Ctenants,\u001b[1C4\u001b[1Cdoctors,\u001b[2C│\r\r\n\u001b[2C│\u001b[1C1\u001b[5C│\u001b[1C\u001b[1mDatabase\u001b[1C\u001b[22m│\u001b[1CDone\u001b[3C│\u001b[1C8\u001b[1Cpatients,\u001b[1C31\u001b[1Cappointments,\u001b[1Cvisit\u001b[1Cnotes,\u001b[1Cbilling,\u001b[1C│\r\r\n\u001b[2C│\u001b[7C│\u001b[10C│\u001b[8C│\u001b[2Cinsurance\u001b[1Cverifications\u001b[27C│\r\r\n\u001b[2C├───────┼──────────┼────────┼────────────────────────────────────────────────────┤\r\r\n\u001b[2C│\u001b[1C1\u001b[5C│\u001b[1C\u001b[1mBackend\u001b[2C\u001b[22m│\u001b[1CDone\u001b[3C│\u001b[1C14\u001b[1Cfiles\u001b[1Cacross\u001b[1C\u001b[94mpackages/api/\u001b[1C\u001b[39m—\u001b[1Call\u001b[1Cmiddleware,\u001b[4C│\r\r\n\u001b[2C│\u001b[7C│\u001b[10C│\u001b[8C│\u001b[1Cservices,\u001b[1Croutes,\u001b[1Cutilities\u001b[1Cfully\u001b[1Cimplemented\u001b[6C│\r\r\n\u001b[2C├───────┼──────────┼───────"]
[0.000, "o", "─┼────────────────────────────────────────────────────┤\r\r\n\u001b[2C│\u001b[1C2\u001b[5C│\u001b[1C\u001b[1mFrontend\u001b[1C\u001b[22m│\u001b[1CDone\u001b[3C│\u001b[1C30+\u001b[1Cfiles\u001b[1Cacross\u001b[1C\u001b[94mpackages/web/\u001b[1C\u001b[39m—\u001b[1C10\u001b[1CUI\u001b[1Ccomponents,\u001b[1C│\r\r\n\u001b[2C│\u001b[7C│\u001b[10C│\u001b[8C│\u001b[2C3\u001b[1Cforms,\u001b[1C5\u001b[1Cdata\u001b[1Cdisplays,\u001b[1C8\u001b[1Cpages,\u001b[1Cauth\u001b[1Cprovider\u001b[2C│\r\r\n\u001b[2C├───────┼──────────┼────────┼────────────────────────────────────────────────────┤\r\r\n\u001b[2C│\u001b[7C│\u001b[10C│\u001b[8C│\u001b[1CCI/CD\u001b[1Cpipeline\u001b[1C(5-gate),\u001b[1CDockerfile,\u001b[15C│\r\r\n\u001b[2C│\u001b[1C2\u001b[5C│\u001b[1C\u001b[1mDevOps\u001b[3C\u001b[22m│\u001b[1CDone\u001b[3C│\u001b[1Cdocker-compose,\u001b[1CTerraform,\u001b[1Cbackup/rotation\u001b[9C│\r\r\n\u001b[2C│\u001b[7C│\u001b[10C│\u001b[8C│\u001b[1Cscripts,\u001b[1C\u001b[94m.env.example\u001b[30C\u001b[39m│\r\r\n\u001b[2C├───────┼───"]
[0.000, "o", "───────┼────────┼────────────────────────────────────────────────────┤\r\r\n\u001b[2C│\u001b[1C3\u001b[5C│\u001b[1C\u001b[1mQA\u001b[7C\u001b[22m│\u001b[1CDone\u001b[3C│\u001b[1C9\u001b[1Ctest\u001b[1Csuites,\u001b[1C2,260\u001b[1Clines\u001b[1C—\u001b[1Cmiddleware,\u001b[1Cservices,\u001b[1C│\r\r\n\u001b[2C│\u001b[7C│\u001b[10C│\u001b[8C│\u001b[2Croutes,\u001b[1Cpermissions\u001b[31C│\r\r\n\u001b[2C└───────┴──────────┴────────┴────────────────────────────────────────────────────┘\r\r\n\r\r\n\u001b[2C\u001b[1mGovernance\u001b[1CCompliance\u001b[22m\r\r\n\r\r\n\u001b[2C-\u001b[1C\u001b[1mLedger\u001b[22m:\u001b[1C5\u001b[1Centries\u001b[1Clogged\u001b[1C(one\u001b[1Cper\u001b[1Cagent),\u001b[1Chandoffs\u001b[1Ctracked\u001b[1Cvia\r\r\n\u001b[2C\u001b[94mrequires_attention_from\u001b[39m\r\r\n\u001b[2C-\u001b[1C\u001b[1mConstitution\u001b[22m:\u001b[1CAll\u001b[1C6\u001b[1Cprinciples\u001b[1Cenforced\u001b[1C—\u001b[1CHIPAA\u001b[1Ccompliance,\u001b[1Ctenant\u001b[1Cisolation,\r\r\n\u001b[2Caudit\u001b[1Ccompleteness,\u001b"]
