# ==============================================================================
# ClearHealth Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env files with real values to version control.
# ==============================================================================

# Database
DATABASE_URL=postgresql://clearhealth:clearhealth_dev@localhost:5432/clearhealth
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379

# Auth — JWT tokens
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-64-byte-hex-secret
JWT_REFRESH_SECRET=replace-with-different-64-byte-hex-secret
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption — AES-256-GCM for patient data at rest (SSN, etc.)
# MUST be exactly 64 hex characters (32 bytes).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-hex-char-key-generated-by-openssl-rand-hex-32xx
ENCRYPTION_ALGORITHM=aes-256-gcm

# AWS (required for production deployments, document storage, and backups)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=clearhealth-documents

# Insurance Verification API
INSURANCE_API_URL=https://api.insuranceverify.example.com
INSURANCE_API_KEY=your-insurance-api-key

# Notifications (optional — stubs used if not configured)
SENDGRID_API_KEY=your-sendgrid-api-key
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Logging & Audit
LOG_LEVEL=info
AUDIT_LOG_ENABLED=true
