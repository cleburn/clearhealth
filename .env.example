# ==============================================================================
# ClearHealth Environment Configuration
# ==============================================================================
# Copy this file to .env and fill in the values for your environment.
# NEVER commit .env files with real values to version control.
# ==============================================================================

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/clearhealth
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Encryption (patient data at rest)
ENCRYPTION_KEY=32-byte-hex-key-here
ENCRYPTION_ALGORITHM=aes-256-gcm

# AWS
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_REGION=us-east-1
S3_BUCKET_NAME=clearhealth-documents

# Insurance Verification API
INSURANCE_API_URL=https://api.insuranceverify.example.com
INSURANCE_API_KEY=your-api-key

# Notifications
SENDGRID_API_KEY=your-sendgrid-key
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# Application
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=info
AUDIT_LOG_ENABLED=true
