[0.079, "o", "\u001b[?2026h\r\u001b[14A\u001b[37m⏺\r\u001b[8B\u001b[94m──────────────────────────────────────────────────────────────────────────────────────\r\u001b[1C\u001b[1B\u001b[1mBash command\r\u001b[1B\u001b[22m\u001b[39m                                                                  \u001b[1C   \u001b[1C      \u001b[1C      \u001b[1C \r\u001b[1B   python3\u001b[1C-c\u001b[1C\"\r\u001b[1B   import yaml, sys                                                                   \r\u001b[2C\u001b[1B files = [                                                \r\r\n\u001b[5C'.github/workflows/ci.yml',\r\r\n\u001b[5C'.github/workflows/deploy.yml',\r\r\n\u001b[5C'docker-compose.yml',\r\r\n\u001b[5C'docker-compose.test.yml',\r\r\n\u001b[3C]\r\r\n\u001b[3Cfor\u001b[1Cf\u001b[1Cin\u001b[1Cfiles:\r\r\n\u001b[5Ctry:\r\r\n\u001b[7Cwith\u001b[1Copen(f)\u001b[1Cas\u001b[1Cfh:\r\r\n\u001b[9Cyaml.safe_load(fh)\r\r\n\u001b[7Cprint(f'{f}:\u001b[1COK')\r\r\n\u001b[5Cexcept\u001b[1CException\u001b[1Cas\u001b[1Ce:\r\r\n\u001b[7Cprint(f'{f}:\u001b[1CERROR\u001b[1C-\u001b[1C{e}')\r\r\n\u001b[7Csys.exit(1)\r\r\n\u001b[3C\"\r\r\n\u001b[3C\u001b[37mValidate\u001b[1CYAML\u001b[1Csynt"]
